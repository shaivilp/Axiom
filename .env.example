# Dashboard authentication
# Generate with: openssl rand -hex 32 (or any long random string)
DASHBOARD_TOKEN=replace-with-long-random-string

# Token encryption (exactly 32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=afkbot
POSTGRES_USER=afkbot
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://afkbot:replace-me@postgres:5432/afkbot

# Server
PORT=3005
NODE_ENV=production
LOG_LEVEL=info

# Host port the dashboard (nginx) is published on. Maps to container :80.
HOST_PORT=5005

# CORS — frontend origin (the URL where the dashboard is reachable)
ALLOWED_ORIGIN=http://localhost:5005
