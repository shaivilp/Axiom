# Dashboard authentication
# Generate with: openssl rand -hex 32 (or any long random string)
DASHBOARD_TOKEN=replace-with-long-random-string

# Token encryption (exactly 32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=afkbot
POSTGRES_USER=afkbot
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://afkbot:replace-me@postgres:5432/afkbot

# Server
PORT=3005
NODE_ENV=production
LOG_LEVEL=info

# Host ports the dashboard (nginx) is published on.
#   HOST_PORT  → container :80  (plain HTTP, handy for LAN access)
#   HTTPS_PORT → container :443 (TLS via the Cloudflare Origin Certificate)
HOST_PORT=5005
HTTPS_PORT=443

# Dashboard origin — the exact URL you load in the browser.
# Over HTTPS this MUST be https:// — it both satisfies the production
# HTTPS check AND flips the session cookie to Secure.
#   LAN HTTP:        http://localhost:5005
#   Cloudflare/TLS:  https://alts.shaivilpatel.me
ALLOWED_ORIGIN=https://alts.shaivilpatel.me
