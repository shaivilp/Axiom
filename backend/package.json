{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bunx tsc -p tsconfig.build.json",
    "start": "bun src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "prisma:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate deploy",
    "db:migrate:dev": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "postinstall": "bunx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.1.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "mineflayer": "4.27.0",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "prisma": "6.1.0",
    "prismarine-auth": "2.7.0",
    "ws": "8.18.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/supertest": "6.0.2",
    "supertest": "7.0.0",
    "@types/node": "22.10.5",
    "@types/ws": "8.5.13",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
