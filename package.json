{
  "name": "afkbot",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Minecraft AFK bot with multi-account support and web dashboard",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
